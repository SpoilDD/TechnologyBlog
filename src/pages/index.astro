---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedPost from '../components/FeaturedPost.astro';
import PostItem from '../components/PostItem.astro';
import FilterBar from '../components/FilterBar.astro';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = allPosts.find((p) => p.data.featured);
const others = allPosts.filter((p) => !p.data.featured);

const totalPosts = allPosts.length;
const categories = new Set(allPosts.map((p) => p.data.category)).size;
const earliestYear = allPosts.length
  ? Math.min(...allPosts.map((p) => p.data.pubDate.getFullYear()))
  : new Date().getFullYear();
---
<BaseLayout title="// dev.log — 技术美术笔记">
  <header class="hero">
    <div class="container">
      <div class="hero-prompt">whoami<span class="blink"></span></div>
      <h1 class="hero-title">写在 <span>渲染</span> 与 <span>工程</span><br />中间的笔记</h1>
      <p class="hero-desc">
        技术美术 / 实时渲染 / Shader 开发 / 工具研发<br />
        记录一些踩坑、思考与解法。不定期更新。
      </p>
      <div class="hero-stats">
        <div class="stat-item">
          <div class="stat-value">{totalPosts}</div>
          <div class="stat-label">Articles</div>
        </div>
        <div class="stat-item">
          <div class="stat-value">{categories}</div>
          <div class="stat-label">Categories</div>
        </div>
        <div class="stat-item">
          <div class="stat-value">{earliestYear}</div>
          <div class="stat-label">Since</div>
        </div>
      </div>
    </div>
  </header>

  <FilterBar />

  <section class="posts">
    <div class="container">
      {featured && <FeaturedPost post={featured} />}

      <div class="posts-section-label">Recent Posts</div>

      <div class="post-list">
        {others.map((post) => <PostItem post={post} />)}
      </div>

      <p id="no-results" class="no-results" style="display:none">
        // 该分类下暂无文章
      </p>
    </div>
  </section>
</BaseLayout>
