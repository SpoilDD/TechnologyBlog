---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import Comments from '../components/Comments.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  headings?: MarkdownHeading[];
}

const { post, headings = [] } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth >= 1 && h.depth <= 3);
const date = post.data.pubDate;
const dateStr = `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
const readTime = Math.max(1, Math.round((post.body?.length ?? 0) / 600));
---
<BaseLayout title={`${post.data.title} · KiteAidan`} description={post.data.description}>
  {tocHeadings.length > 0 && (
    <aside class="article-toc" aria-label="Table of contents">
      <div class="article-toc-title">// CONTENTS</div>
      <nav>
        <ul>
          {tocHeadings.map((h) => (
            <li class={`toc-h${h.depth}`}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )}
  <article class="article container">
    <header class="article-header">
      <a href="/" class="article-back">Back to all posts</a>
      <div class="article-meta">
        <span>{dateStr}</span>
        <span class="dot"></span>
        <span>{readTime} min read</span>
        <span class="dot"></span>
        <span>#{post.data.category}</span>
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-desc">{post.data.description}</p>
      <div class="article-tags">
        {post.data.tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    </header>

    <div class="article-body">
      <slot />
    </div>

    <footer class="article-footer">
      <a href="/">← 返回文章列表</a>
      <span>感谢阅读 · 欢迎在下方评论</span>
    </footer>

    <Comments />
  </article>

  <!-- 图片放大灯箱 -->
  <div id="lightbox" class="lightbox" aria-hidden="true">
    <button class="lightbox-close" aria-label="关闭">×</button>
    <img class="lightbox-img" src="" alt="" />
  </div>
</BaseLayout>

<script>
  const lightbox = document.getElementById('lightbox');
  if (lightbox) {
    const lbImg = lightbox.querySelector('.lightbox-img') as HTMLImageElement;
    const images = document.querySelectorAll<HTMLImageElement>('.article-body img');

    const open = (src: string, alt: string) => {
      lbImg.src = src;
      lbImg.alt = alt;
      lightbox.classList.add('open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const close = () => {
      lightbox.classList.remove('open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    images.forEach((img) => {
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', () => open(img.currentSrc || img.src, img.alt));
    });

    lightbox.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox.classList.contains('open')) close();
    });
  }
</script>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4vmin;
    background: rgba(0, 0, 0, 0.88);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
    cursor: zoom-out;
  }

  .lightbox.open {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox-img {
    max-width: 100%;
    max-height: 92vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
    transform: scale(0.96);
    transition: transform 0.25s ease;
  }

  .lightbox.open .lightbox-img {
    transform: scale(1);
  }

  .lightbox-close {
    position: absolute;
    top: 1.2rem;
    right: 1.6rem;
    width: 2.4rem;
    height: 2.4rem;
    font-size: 1.8rem;
    line-height: 1;
    color: #fff;
    background: transparent;
    border: none;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .lightbox-close:hover {
    opacity: 1;
  }
</style>
