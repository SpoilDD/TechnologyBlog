---
// Giscus 评论组件
// 配置位置: 改下面 5 个 data-* 属性即可
// 到 https://giscus.app 生成你自己的配置
---
<section class="comments">
  <h3 class="comments-title">// COMMENTS</h3>
  <script
    src="https://giscus.app/client.js"
    data-repo="SpoilDD/TechnologyBlog"
    data-repo-id="R_kgDOSQmc_Q"
    data-category="Announcements"
    data-category-id="DIC_kwDOSQmc_c4C9yya"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="bottom"
    data-theme="noborder_dark"
    data-lang="zh-CN"
    data-loading="lazy"
    crossorigin="anonymous"
    async
  ></script>
</section>

<style>
  .comments {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .comments-title {
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--cyan);
    margin-bottom: 1.5rem;
  }

  /* Giscus iframe 边距 */
  .comments :global(.giscus),
  .comments :global(.giscus-frame) {
    width: 100%;
  }
</style>
