---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const date = post.data.pubDate;
const dateStr = `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
const readTime = Math.max(1, Math.round((post.body?.length ?? 0) / 600));

const categoryLabels: Record<string, string> = {
  shader: 'SHADER',
  math: 'MATH',
  optimize: 'OPTIMIZE',
};
---
<a
  href={`/blog/${post.id}`}
  class:list={['post-card', 'reveal', featured && 'featured']}
  data-cat={post.data.category}
>
  <div class="post-thumb">
    <span class="post-thumb-icon">{post.data.icon}</span>
    <span class="post-thumb-cat">{categoryLabels[post.data.category]}</span>
  </div>
  <div class="post-info">
    <div class="post-meta">
      <span>{dateStr}</span>
      <span class="dot"></span>
      <span>{readTime} min read</span>
    </div>
    <h3 class="post-title">{post.data.title}</h3>
    <p class="post-excerpt">{post.data.description}</p>
    <div class="post-tags">
      {post.data.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </div>
</a>
