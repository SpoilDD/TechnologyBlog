---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const date = post.data.pubDate;
const dateStr = `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
const readTime = Math.max(1, Math.round((post.body?.length ?? 0) / 600));
---
<a
  href={`/blog/${post.id}`}
  class:list={['post-card', 'reveal', featured && 'featured']}
  data-cat={post.data.category}
>
  <div class="post-info">
    <div class="post-meta">
      <span>{dateStr}</span>
      <span class="dot"></span>
      <span>{readTime} min read</span>
    </div>
    <h3 class="post-title">{post.data.title}</h3>
    <p class="post-excerpt">{post.data.description}</p>
    <div class="post-tags">
      {post.data.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </div>

  {post.data.cover ? (
    <div class="post-cover">
      <Image src={post.data.cover} alt={post.data.title} width={440} densities={[1, 2]} />
    </div>
  ) : (
    <div class="post-cover post-cover--fallback">
      <span class="post-cover-icon">{post.data.icon}</span>
    </div>
  )}
</a>
